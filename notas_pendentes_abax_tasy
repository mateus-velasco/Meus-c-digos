       STATUS LIKE '%____________________________________76______________________________________________________________' OR
       STATUS LIKE '%____________________________________69______________________________________________________________' OR
       STATUS LIKE '%____________________________________AA______________________________________________________________' OR
       STATUS LIKE '%____________________________________SS______________________________________________________________' OR
       STATUS LIKE '%____________________________________AL______________________________________________________________') AND
       (STATUS LIKE '%____________________________35______________________________________________________________________'))
   AND B.B11_TPNF = 1
   AND B.B09_DEMI BETWEEN '20251101 00:00:00' AND '20260519 23:59:59'
   AND (DOC.NOTA_RESTRITA = 'N' OR ISNULL(DOC.NOTA_RESTRITA, '') = '')
   AND (DOC.MODULO = 'INBOUND' OR ISNULL(DOC.MODULO, '') = '')
