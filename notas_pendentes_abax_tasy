  FROM ZDW_A01_INFNFE A
  JOIN ZDW_B01_IDE B ON (B.A01_ID = A.A01_ID)
  JOIN DOCUMENTO DOC ON (DOC.ID = A.IDDOCUMENTO)
  JOIN ZDW_C01_EMIT C ON (C.A01_ID = A.A01_ID)
  JOIN ZDW_E01_DEST E ON (E.A01_ID = A.A01_ID)
  LEFT JOIN ANOMALIA AN ON (DOC.IDANOMALIA = AN.ID)
  LEFT OUTER JOIN ZDW_E05_ENDERDEST E5 ON (E5.E01_ID = E.E01_ID)
  LEFT OUTER JOIN ZDW_W01_TOTAL W1 ON (W1.A01_ID = A.A01_ID)
  LEFT OUTER JOIN ZDW_W02_ICMSTOT W2 ON (W2.W01_ID = W1.W01_ID)
  LEFT OUTER JOIN ZDW_W03_IBSCBSTOT IB ON (IB.A01_ID = A.A01_ID)
  LEFT OUTER JOIN ZDW_H01_DET H01 ON (H01.A01_ID = A.A01_ID)
  LEFT OUTER JOIN ZDW_M01_IMPOSTO M01 ON (M01.H01_ID = H01.H01_ID)
  LEFT OUTER JOIN ZDW_N01_ICMS N01 ON (N01.M01_ID = M01.M01_ID)
  LEFT OUTER JOIN ZDW_N10C_ICMSSN101 N10C ON (N10C.N01_ID = N01.N01_ID)
  LEFT OUTER JOIN ZDW_N10E_ICMSSN201 N10E ON (N10E.N01_ID = N01.N01_ID)
  LEFT OUTER JOIN DEPARA_VINCULO DV ON (DOC.ID = DV.ID_DOCUMENTO)
  LEFT OUTER JOIN REGRAFISCAL R ON (DV.ID = R.ID_DEPARA)
  LEFT OUTER JOIN ZDW_Z01_INFADIC Z ON (Z.A01_ID = A.A01_ID)
 WHERE TIPODOCUMENTO <> 2
   AND ((STATUS LIKE '%______03____________________________________________________________________________________________' OR
       STATUS LIKE '%______04____________________________________________________________________________________________' OR
       STATUS LIKE '%______87____________________________________________________________________________________________') AND
       (STATUS LIKE '%____01______________________________________________________________________________________________' OR
       STATUS LIKE '%____38______________________________________________________________________________________________' OR
       STATUS LIKE '%____75______________________________________________________________________________________________' OR
       STATUS LIKE '%____65______________________________________________________________________________________________' OR
       STATUS LIKE '%____66______________________________________________________________________________________________' OR
       STATUS LIKE '%____BF______________________________________________________________________________________________') AND
